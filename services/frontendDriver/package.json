{
	"name": "gotofrontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test"
	},
	"devDependencies": {
		"@bufbuild/buf": "^1.72.0",
		"@bufbuild/protoc-gen-es": "^2.12.1",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.24.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "8.0.0-next.1",
		"@sveltejs/kit": "3.0.0-next.10",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.3.0",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.8",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"shadcn-svelte": "^1.4.2",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"pnpm": {
		"peerDependencyRules": {
			"allowedVersions": {
				"runed>@sveltejs/kit": "3.0.0-next.10"
			}
		}
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@bufbuild/protobuf": "^2.12.1",
		"@connectrpc/connect": "^2.1.2",
		"@connectrpc/connect-web": "^2.1.2",
		"@fontsource-variable/cascadia-code": "^5.2.2",
		"@tanstack/svelte-query": "^6.1.36",
		"class-variance-authority": "^0.7.1",
		"leaflet": "^1.9.4",
		"lucide-react": "^1.24.0",
		"shadcn": "^4.13.0"
	}
}
